import os, shutil, subprocess, json, typing, argparse

class GitSourceConfig(typing.TypedDict):
    type: typing.Literal["git"]
    remote: str
    branch: typing.Optional[str]
SourceConfig = GitSourceConfig

class MakeBuildConfig(typing.TypedDict):
    type: typing.Literal["make"]
class CommandBuildConfig(typing.TypedDict):
    type: typing.Literal["command"]
    command: str
BuildConfig = MakeBuildConfig | CommandBuildConfig

class PackageConfig(typing.TypedDict):
    source: SourceConfig
    build: BuildConfig

data_dir = os.environ.get("BMAN_DATA_DIR", os.path.expanduser(f"~/.local/share/bman"))
config_dir = os.environ.get("BMAN_CONFIG_DIR", os.path.expanduser(f"~/.config/bman"))

def build_package(pkg_name: str, config: PackageConfig) -> None:
    if config["build"]["type"] == "make":
        subprocess.run(["make", f"-j{os.cpu_count()}"], cwd=f"{data_dir}/{pkg_name}")
    elif config["build"]["type"] == "command":
        subprocess.run(config["build"]["command"], cwd=f"{data_dir}/{pkg_name}", shell=True)
    else:
        raise Exception(f"unknown build type {config.build.type}")

def install_package(pkg_name: str, config: PackageConfig) -> None:
    clone_command = ["git", "clone", config["source"]["remote"], pkg_name, "--depth", "1"]
    if config["source"]["branch"] is not None:
        clone_command += ["--branch", config["source"]["branch"]]
    subprocess.run(clone_command, cwd=data_dir)
    subprocess.run(["git", "submodule", "update", "--init"], cwd=f"{data_dir}/{pkg_name}")
    build_package(pkg_name, config)
    with open(f"{config_dir}/{pkg_name}.json", "w") as f:
        json.dump(config, f)

def remove_package(pkg_name: str) -> None:
    shutil.rmtree(f"{data_dir}/{pkg_name}")
    os.remove(f"{config_dir}/{pkg_name}.json")

def update_package(pkg_name: str) -> None:
    with open(f"{config_dir}/{pkg_name}.json") as f:
        config: PackageConfig = json.load(f)
    subprocess.run(["git", "pull"], cwd=f"{data_dir}/{pkg_name}")
    subprocess.run(["git", "submodule", "update"], cwd=f"{data_dir}/{pkg_name}")
    build_package(pkg_name, config)

def update_packages() -> None:
    for pkg in os.listdir(config_dir):
        if not pkg.endswith(".json"):
            continue
        update_package(pkg[:-5])

def main() -> None:
    if not os.path.isdir(data_dir):
        os.mkdir(data_dir)
    if not os.path.isdir(config_dir):
        os.mkdir(config_dir)

    parser = argparse.ArgumentParser(description="manage packages built from upstream sources")
    subparsers = parser.add_subparsers(dest="command")

    install = subparsers.add_parser("install", help="install a package")
    install.add_argument("name", help="package name")
    install.add_argument("repo", help="package repository URL")
    install.add_argument("--build", help="build command")
    install.add_argument("--branch", default=None, help="target branch")

    install_config = subparsers.add_parser("install-config", help="install a package from a config file")
    install_config.add_argument("name", help="package name")
    install_config.add_argument("config", help="name of config file")

    remove = subparsers.add_parser("remove", help="remove a package")
    remove.add_argument("name", nargs="*", help="package names")

    update = subparsers.add_parser("update", help="update all packages")
    update.add_argument("name", nargs="*", help="package names")

    subparsers.add_parser("reset", help="delete all packages and data")

    get_config = subparsers.add_parser("get-config", help="print the json config for a package")
    get_config.add_argument("name", help="package name")

    args = parser.parse_args()

    if args.command == "install":
        config = PackageConfig(
            source = GitSourceConfig(type="git", remote=args.repo, branch=args.branch),
            build = MakeBuildConfig(type="make") if args.build is None else CommandBuildConfig(type="command", command=args.build)
        )
        install_package(args.name, config)
    elif args.command == "install-config":
        with open(args.config) as f:
            config = json.load(f)
        install_package(args.name, config)
    elif args.command == "remove":
        for name in args.name:
            remove_package(name)
    elif args.command == "update":
        if len(args.name) == 0:
            update_packages()
        else:
            for name in args.name:
                update_package(name)
    elif args.command == "reset":
        shutil.rmtree(data_dir)
        shutil.rmtree(config_dir)
    elif args.command == "get-config":
        with open(f"{config_dir}/{args.name}.json") as f:
            config = json.load(f)
        print(json.dumps(config, indent=4))
    else:
        parser.print_help()
        parser.exit(1)

if __name__ == "__main__":
    main()
