import sys, os, shutil, subprocess, json

NAME = "bman"

data_dir = os.path.expanduser(f"~/.local/share/{NAME}")
config_dir = os.path.expanduser(f"~/.config/{NAME}")

if not os.path.isdir(data_dir):
    os.mkdir(data_dir)
if not os.path.isdir(config_dir):
    os.mkdir(config_dir)

def assert_n_args(n):
    if len(sys.argv) != n:
        exit(f"{NAME}: expected {n} arguments")

def install_package(pkg_name, config):
    with open(f"{config_dir}/{pkg_name}.json", "w") as f:
        json.dump(config, f)
    os.chdir(f"{data_dir}")
    os.system(f"git clone {config["source"]["remote"]} {pkg_name} --depth 1")
    os.chdir(pkg_name)
    os.system("make")

def remove_package(pkg_name):
    shutil.rmtree(f"{data_dir}/{pkg_name}")
    os.remove(f"{config_dir}/{pkg_name}.json")

def update_packages():
    for pkg in os.listdir(config_dir):
        if not pkg.endswith(".json"):
            continue
        with open(f"{config_dir}/{pkg}") as f:
            config = json.load(f)
        pkg = pkg[:-5]
        os.chdir(f"{data_dir}/{pkg}")
        os.system("git pull")
        os.system("make")

if len(sys.argv) < 2:
    exit(f"{NAME}: not enough arguments")

if sys.argv[1] == "install":
    assert_n_args(4)
    install_package(sys.argv[2], {
        "source": {
            "type": "git",
            "remote": sys.argv[3],
        }
    })
elif sys.argv[1] == "remove":
    assert_n_args(3)
    remove_package(sys.argv[2])
elif sys.argv[1] == "update":
    assert_n_args(2)
    update_packages()
elif sys.argv[1] == "reset":
    assert_n_args(2)
    shutil.rmtree(data_dir)
    shutil.rmtree(config_dir)
